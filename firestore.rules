rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.role == 'admin' || getUserRole() == 'admin');
    }

    function isWarehouseSupervisor() {
      return isAuthenticated() && (request.auth.token.role == 'warehouse_supervisor' || getUserRole() == 'warehouse_supervisor');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /ageing_data/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isWarehouseSupervisor();
    }

    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isWarehouseSupervisor();
    }
    
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
