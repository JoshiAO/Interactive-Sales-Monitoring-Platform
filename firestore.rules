rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getDbUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.role == 'admin' || getDbUser().role == 'admin');
    }

    function isWarehouseSupervisor() {
      return isAuthenticated() && (request.auth.token.role == 'warehouse_supervisor' || getDbUser().role == 'warehouse_supervisor');
    }

    function isManagerOrAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.role == 'manager' || 
        getDbUser().role == 'admin' || 
        getDbUser().role == 'manager'
      );
    }

    function isSupervisor() {
      return isAuthenticated() && (request.auth.token.role == 'supervisor' || getDbUser().role == 'supervisor');
    }

    function isOwner(salesmanId) {
      return isAuthenticated() && (request.auth.token.salesmanId == salesmanId || getDbUser().salesmanId == salesmanId);
    }

    function isSupervisorOf(teamName) {
      return isSupervisor() && teamName != null && (
        (request.auth.token.team != null && request.auth.token.team.matches('.*' + teamName + '.*')) ||
        (getDbUser().team != null && getDbUser().team.matches('.*' + teamName + '.*'))
      );
    }

    // Role-Based Row-Level Security (RLS)
    match /users/{userId} { 
      allow read: if isAuthenticated();
      allow write: if isAdmin(); 
    }
    
    match /dashboard_metrics/{docId} { 
      allow read: if isManagerOrAdmin() || isOwner(docId) || isSupervisor(); 
      allow write: if isAdmin(); 
    }
    
    match /dashboard_metrics_summary/{document=**} { 
      allow read: if isAuthenticated(); 
      allow write: if isAdmin(); 
    }
    
    match /customer_data/{docId} { 
      allow read: if isManagerOrAdmin() || isOwner(docId) || isSupervisor(); 
      allow write: if isAdmin(); 
    }

    // Publicly readable collections (for all authenticated users)
    match /settings/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin() || isWarehouseSupervisor(); }
    match /salesman_targets/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /vd30_targets/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_team_service/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_vd30/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_channels/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_geo/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_customer_classes/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_masterlist/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_ads/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /reference_pricelist/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /incentives_programs/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /incentives_targets/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /npd_promopack_items/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /npd_promopack_metrics/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /achievements/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /historical_medals/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /trade_bo_history/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /van_bo_history/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /warehouse_bo_history/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /van_bo_data/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /snapshots/{document=**} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    
    match /ageing_data/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isWarehouseSupervisor();
    }
    
    match /warehouse_bo_data/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isWarehouseSupervisor();
    }

    // Gamification commitments (users can write their own, or admin can write all. For now we keep it open for authenticated)
    match /weekly_commitments/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Default deny for any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
